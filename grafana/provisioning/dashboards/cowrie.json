    {
      "id": 21,
      "title": "Unique Malware Hashes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 38 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(DISTINCT shasum) AS unique_hashes FROM downloads WHERE $__timeFilter(timestamp) AND shasum IS NOT NULL AND shasum != ''",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Top Downloaded URLs",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 4, "y": 38 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.8,
        "fillOpacity": 80,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT url, count(*) AS downloads FROM downloads WHERE $__timeFilter(timestamp) AND url IS NOT NULL GROUP BY url ORDER BY downloads DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Malware Hashes",
      "type": "table",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 38 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "downloads", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT substring(url FROM '[^/]+$') AS filename, shasum, count(*) AS downloads FROM downloads WHERE $__timeFilter(timestamp) AND shasum IS NOT NULL AND shasum != '' GROUP BY filename, shasum ORDER BY downloads DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 24,
      "collapsed": false,
      "title": "Timing Patterns",
