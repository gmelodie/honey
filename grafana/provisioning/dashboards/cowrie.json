{
  "title": "Cowrie Dashboard",
  "uid": "cowrie-postgres-dash",
  "description": "Cowrie honeypot overview — data from PostgreSQL",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "refresh": "1m",
  "schemaVersion": 40,
  "tags": ["cowrie", "honeypot"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "title": "Total Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(DISTINCT session) AS connections FROM auth WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Unique Sessions (commands)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(DISTINCT session) AS unique_sessions FROM input WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
