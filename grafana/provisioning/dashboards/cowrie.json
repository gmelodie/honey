        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT LPAD(EXTRACT(HOUR FROM timestamp)::int::text, 2, '0') || ':00' AS hour, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) GROUP BY EXTRACT(HOUR FROM timestamp)::int ORDER BY EXTRACT(HOUR FROM timestamp)::int",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 26,
      "title": "Attacks by Day of Week",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.8,
        "fillOpacity": 80,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "vertical",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT TO_CHAR(timestamp, 'Dy') AS day, EXTRACT(DOW FROM timestamp)::int AS dow, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) GROUP BY day, dow ORDER BY dow",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 27,
      "title": "Success Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 57 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT $__timeGroup(timestamp, $__interval) AS time, round(sum(CASE WHEN success THEN 1 ELSE 0 END)::numeric / NULLIF(count(*), 0), 4) AS \"success rate\" FROM auth WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 28,
      "collapsed": false,
      "title": "Client Fingerprints",
