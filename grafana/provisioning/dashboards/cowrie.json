{
  "title": "Cowrie Dashboard",
  "uid": "cowrie-postgres-dash",
  "description": "Cowrie honeypot overview — data from PostgreSQL",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "refresh": "1m",
  "schemaVersion": 40,
  "tags": ["cowrie", "honeypot"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "title": "Total Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(*) AS connections FROM sessions WHERE $__timeFilter(starttime)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Unique Attacking IPs",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(DISTINCT ip) AS unique_ips FROM sessions WHERE $__timeFilter(starttime)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Auth Attempts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Commands Executed",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT count(*) AS commands FROM input WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top Attacking IPs",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "connections", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "connections" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT ip, count(*) AS connections, min(starttime) AS first_seen, max(starttime) AS last_seen FROM sessions WHERE $__timeFilter(starttime) GROUP BY ip ORDER BY connections DESC LIMIT 25",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top Usernames Attempted",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.8,
        "fillOpacity": 80,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT username, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) GROUP BY username ORDER BY attempts DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Top Passwords Attempted",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.8,
        "fillOpacity": 80,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT password, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) GROUP BY password ORDER BY attempts DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top Credential Pairs",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "attempts", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT username, password, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) GROUP BY username, password ORDER BY attempts DESC LIMIT 25",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "collapsed": false,
      "title": "Login Stats",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 10,
      "title": "Failed Logins",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT $__timeGroup(timestamp, $__interval) AS time, count(*) AS \"failed logins\" FROM auth WHERE $__timeFilter(timestamp) AND success = false GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Successful Logins",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT $__timeGroup(timestamp, $__interval) AS time, count(*) AS \"successful logins\" FROM auth WHERE $__timeFilter(timestamp) AND success = true GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "\"ubuntu\" Failed Logins",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT $__timeGroup(timestamp, $__interval) AS time, count(*) AS \"login attempt\" FROM auth WHERE $__timeFilter(timestamp) AND username = 'ubuntu' AND success = false GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "\"ubuntu\" Passwords Used",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "barRadius": 0,
        "barWidth": 0.8,
        "fillOpacity": 80,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT password, count(*) AS attempts FROM auth WHERE $__timeFilter(timestamp) AND username = 'ubuntu' GROUP BY password ORDER BY attempts DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "collapsed": false,
      "title": "Activity Log",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }
    },
    {
      "id": 15,
      "title": "Commands",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 46 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "time" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "src_ip" },
            "properties": [{ "id": "custom.width", "value": 130 }]
          },
          {
            "matcher": { "id": "byName", "options": "session" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT i.timestamp AS time, s.ip AS src_ip, i.session, i.input FROM input i JOIN sessions s ON i.session = s.id WHERE $__timeFilter(i.timestamp) ORDER BY i.timestamp DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Sessions",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 56 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "starttime", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT s.starttime, s.endtime, s.ip, s.id AS session, s.client FROM sessions s WHERE $__timeFilter(s.starttime) ORDER BY s.starttime DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "title": "Downloads",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 66 },
      "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "cowrie-postgres" },
          "rawSql": "SELECT d.timestamp AS time, s.ip AS src_ip, d.url, d.outfile, d.shasum FROM downloads d JOIN sessions s ON d.session = s.id WHERE $__timeFilter(d.timestamp) ORDER BY d.timestamp DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
