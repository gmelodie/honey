# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=cowrie
POSTGRES_USER=cowrie
POSTGRES_PASSWORD=strongpassword

# ── reCAPTCHA v2 ("I'm not a robot" checkbox) ────────────────────────────────
# Register at https://www.google.com/recaptcha/admin/create  (type: v2 Checkbox)
RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RECAPTCHA_SECRET_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Malware hash analysis ─────────────────────────────────────────────────────
# MalwareBazaar (abuse.ch) is always queried — no key needed.
# VirusTotal is optional; leave blank to skip it.
VIRUSTOTAL_API_KEY=

# ── Nginx routing ─────────────────────────────────────────────────────────────
# Requests with this Host header are routed to the stats dashboard.
# All other hosts go to the web honeypot.
TARGET_HOST=honey.gmelodie.com

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Used by scripts/init-letsencrypt.sh  (not read by docker-compose directly)
CERTBOT_EMAIL=you@example.com
